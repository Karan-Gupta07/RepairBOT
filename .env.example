# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model if default fails (e.g. gemini-1.5-flash-002, gemini-1.5-pro)
# GEMINI_MODEL=gemini-2.0-flash

# Your Shopify store domain (e.g. mystore.myshopify.com or your custom domain)
# Create a Storefront API token in Shopify Admin: Settings > Apps and sales channels > Develop apps
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token_here
